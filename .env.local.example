# Copy this to .env.local and fill in your values

# Neon Postgres (from neon.tech or Vercel Neon integration)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/sausagedb?sslmode=require

# Vercel Blob (from Vercel dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Anthropic Claude API (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
